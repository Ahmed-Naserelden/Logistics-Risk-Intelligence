
LOGISTIC_RISK_INTELLIGENCE_HOME="$HOME/Logistics-Risk-Intelligence"
LOGS_DIR="$LOGISTIC_RISK_INTELLIGENCE_HOME/logs"

# Scripts
SCRIPTS_DIR="$LOGISTIC_RISK_INTELLIGENCE_HOME/scripts"

# Extraction scripts
EXTRACTION_SCRIPTS_DIR="$SCRIPTS_DIR/extraction"

# Vessels scrapping code
VESSELS_SCRAPPER_DIR="$EXTRACTION_SCRIPTS_DIR/vessels_scrapper"
VESSELS_SCRAPPER_CODE="$VESSELS_SCRAPPER_DIR/scraper/vessel-scrapper.py"
SCRAPER_SCRIPT="$VESSELS_SCRAPPER_DIR/script.sh"


export LOGISTIC_RISK_INTELLIGENCE_HOME
export LOGS_DIR
export SCRIPTS_DIR
export VESSELS_SCRAPPER_DIR
export EXTRACTION_SCRIPTS_DIR
export VESSELS_SCRAPPER_CODE
export SCRAPER_SCRIPT
